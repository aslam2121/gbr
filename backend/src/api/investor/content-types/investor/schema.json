{
  "kind": "collectionType",
  "collectionName": "investors",
  "info": {
    "singularName": "investor",
    "pluralName": "investors",
    "displayName": "Investor",
    "description": "Investor profile linked to a user"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "maxLength": 255
    },
    "focus_areas": {
      "type": "text"
    },
    "investment_range": {
      "type": "string",
      "maxLength": 100
    },
    "user": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    }
  }
}
