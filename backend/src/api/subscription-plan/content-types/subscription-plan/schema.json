{
  "kind": "collectionType",
  "collectionName": "subscription_plans",
  "info": {
    "singularName": "subscription-plan",
    "pluralName": "subscription-plans",
    "displayName": "Subscription Plan",
    "description": "Subscription plan with Stripe integration"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "maxLength": 255
    },
    "user_type": {
      "type": "enumeration",
      "enum": ["company", "investor", "expert"],
      "required": true
    },
    "price_monthly": {
      "type": "decimal",
      "required": true
    },
    "price_yearly": {
      "type": "decimal"
    },
    "stripe_price_id_monthly": {
      "type": "string",
      "maxLength": 255
    },
    "stripe_price_id_yearly": {
      "type": "string",
      "maxLength": 255
    },
    "features": {
      "type": "json"
    },
    "is_popular": {
      "type": "boolean",
      "default": false
    },
    "call_minutes": {
      "type": "integer",
      "default": 0
    },
    "directory_listings": {
      "type": "integer",
      "default": 1
    },
    "max_contacts": {
      "type": "integer",
      "default": 10
    }
  }
}
